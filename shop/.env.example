# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=config.settings.develop

# Database (production)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Redis (production)
# REDIS_URL=redis://127.0.0.1:6379/0

# CSRF (production)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Cloudinary (media files in production)
# Формат: cloudinary://api_key:api_secret@cloud_name
# Отримати: https://console.cloudinary.com → Dashboard → API Keys
# CLOUDINARY_URL=cloudinary://123456789012345:your_api_secret@your_cloud_name

# Email
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=shop@lmm.in.ua

# MonoBank Acquiring
# Отримати токен: https://api.monobank.ua/ (тест) або https://web.monobank.ua/ (prod)
MONOBANK_TOKEN=

# Nova Poshta
# API ключ: особистий кабінет https://my.novaposhta.ua → Налаштування → API
NOVA_POSHTA_API_KEY=
# Налаштування відправника (заповнити після отримання доступу до API):
NOVA_POSHTA_SENDER_REF=
NOVA_POSHTA_CONTACT_SENDER_REF=
NOVA_POSHTA_SENDER_CITY_REF=
NOVA_POSHTA_SENDER_WAREHOUSE_REF=
NOVA_POSHTA_SENDER_PHONE=
